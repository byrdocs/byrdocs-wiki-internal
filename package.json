{
  "name": "byrdocs-wiki",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prepare": "husky",
    "lint": "eslint . --ext .js,.cjs,.mjs,.ts,.astro,.md,.mdx --max-warnings=0",
    "lint:fix": "pnpm lint --fix",
    "check": "astro check",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "validate": "pnpm lint && pnpm check && pnpm build",
    "deploy": "pnpm build && wrangler pages deploy"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,astro,md,mdx}": "eslint --max-warnings=0 --fix"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/markdown-remark": "^7.1.0",
    "@astrojs/mdx": "^5.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "katex": "^0.16.45",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-mdx": "^3.7.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript-eslint": "^8.58.2"
  }
}
